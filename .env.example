# Optional override (project also reads hf_token.txt)
HF_TOKEN=hf_your_token_here

# Local gateway (clients connect here)
LOCALLLM_SERVICE__PORT=8090
LOCALLLM_LLM__BASE_URL=http://127.0.0.1:8090/v1
LOCALLLM_LLM__PROVIDER=local

# Model quantization: q6_k (default) | q5_k (5-bit, lower VRAM for dual-GPU with Whisper)
# LOCALLLM_MODEL__QUANTIZATION=q5_k

# Generation limits (chat/agent replies)
# LOCALLLM_GENERATION__MAX_TOKENS=4096
# LOCALLLM_LLAMA_SERVER__CONTEXT_SIZE=16384

# Inference backend (gateway proxies here; internal)
LOCALLLM_LLAMA_SERVER__PORT=8080
LOCALLLM_LLAMA_SERVER__N_GPU_LAYERS=999

# Commercial provider example (set provider=openai and your key)
# LOCALLLM_LLM__PROVIDER=openai
# LOCALLLM_LLM__BASE_URL=https://api.openai.com/v1
# LOCALLLM_LLM__MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# Translator defaults (Translate tab in localllm-streamlit)
# LOCALLLM_TRANSLATE__TARGET_LANGUAGE=es